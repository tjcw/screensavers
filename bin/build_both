function build_one
{
  (
   mkdir -p "${stamp}/$1" &&
   cd "${stamp}/$1" &&
   /home/${SUDO_USER}/eclipse-workspace/screensavers/bin/do_oi "$1" trixie 
   ln live-image-amd64.hybrid.iso "../../isos/$1.iso"
  )
}

stamp="$(date +%Y%m%d-%H%M)"
rm -f isos/freeduc-trixie.iso isos/gk-trixie.iso
mkdir -p isos
export LB_ARCHITECTURE=amd64
build_one freeduc-trixie
build_one gk-trixie
